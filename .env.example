# Copy this file to .env and fill in real values. .env is gitignored.
# See pyproject.toml for which keys are required vs optional.

# ═══════════════════════════════════════════════════════════════
#  Default: LOCAL Ollama backend — $0, no API keys, fully private
# ═══════════════════════════════════════════════════════════════

ITERATE_BACKEND_URL=http://localhost:11434/v1
ITERATE_BACKEND_API_KEY=ollama
ITERATE_MODEL=qwen2.5-coder:14b
ITERATE_BACKEND_TIMEOUT=120

# Run `ollama pull qwen2.5-coder:14b` then `ollama serve` to start.
# Any OpenAI-compatible endpoint works here — just change the URL + model.

# ─── Required: sandbox for code execution ────────────────────
E2B_API_KEY=

# ─── Required: dataset access ────────────────────────────────
KAGGLE_USERNAME=
KAGGLE_KEY=

# ═══════════════════════════════════════════════════════════════
#  Optional: cloud LLM backends (switch ITERATE_BACKEND_URL to use)
# ═══════════════════════════════════════════════════════════════

# Groq — free tier, fast Llama 3.3 70B
# ITERATE_BACKEND_URL=https://api.groq.com/openai/v1
# ITERATE_BACKEND_API_KEY=<your-groq-key>
# ITERATE_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# Together AI — paid, very cheap Llama 3.3 70B
# ITERATE_BACKEND_URL=https://api.together.xyz/v1
# ITERATE_BACKEND_API_KEY=<your-together-key>
# ITERATE_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
TOGETHER_API_KEY=

# Deepseek — paid, strong on code
# ITERATE_BACKEND_URL=https://api.deepseek.com/v1
# ITERATE_BACKEND_API_KEY=<your-deepseek-key>
# ITERATE_MODEL=deepseek-chat
DEEPSEEK_API_KEY=

# OpenAI — for GPT-4/5
OPENAI_API_KEY=

# Anthropic — for Claude (uses separate non-OpenAI-compatible adapter)
ANTHROPIC_API_KEY=

# ─── Optional: logging adapters ──────────────────────────────
NOTION_API_KEY=
NOTION_DATABASE_ID=
SLACK_WEBHOOK_URL=

# ─── Optional: tracing ───────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ─── Local config ────────────────────────────────────────────
ITERATE_MEMORY_DB=.iterate/memory.db
ITERATE_RUNS_DIR=.iterate/runs
